{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Thumb Pipeline Desktop",
  "version": "0.1.0",
  "identifier": "com.thumbpipeline.desktop",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../frontend"
  },
  "app": {
    "windows": [
      {
        "title": "Thumb Pipeline Desktop",
        "width": 1180,
        "height": 820,
        "minWidth": 780,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: asset: http://127.0.0.1:8765; connect-src 'self' http://127.0.0.1:8765; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../dist/backend_server": "_internal"
    }
  }
}
